# Cadena de conexión a tu MongoDB Atlas. REGENERA la contraseña antes de
# usarla aquí — la anterior estuvo expuesta en un repo público.
MONGO_URI=mongodb+srv://usuario:contraseña@cluster0.xxxxx.mongodb.net/APITalok?retryWrites=true&w=majority

# URL del webhook de Discord donde se notifican las limpiezas automáticas.
# Genera uno nuevo en Discord: Ajustes del servidor > Integraciones > Webhooks.
DISCORD_WEBHOOK=https://discord.com/api/webhooks/xxxx/xxxx

# Dominios permitidos a llamar a esta API, separados por comas, sin espacios
# ni barra final. Incluye tu frontend en producción y, si quieres, localhost
# para desarrollo.
ALLOWED_ORIGINS=https://bnotifier.es,https://www.bnotifier.es,http://localhost:5173

# Puerto local (Render lo asigna solo en producción, esto es solo para tu máquina)
PORT=10000
